#include "resource.h"
#include <windows.h>

// Manifest for visual styles
1 RT_MANIFEST "app.manifest"

// Version info
VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "CompanyName", "SimpleTorrent"
            VALUE "FileDescription", "SimpleTorrent - Torrent Downloader"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "SimpleTorrent"
            VALUE "OriginalFilename", "SimpleTorrent.exe"
            VALUE "ProductName", "SimpleTorrent"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1252
    END
END

IDD_SETTINGS DIALOGEX 0, 0, 280, 200
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Opcoes"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Idioma:", IDC_STATIC, 10, 10, 150, 10
    COMBOBOX        IDC_COMBO_LANG, 10, 22, 100, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Pasta padrao para downloads:", IDC_STATIC, 10, 42, 150, 10
    EDITTEXT        IDC_EDIT_SAVEPATH, 10, 54, 210, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_BTN_BROWSE, 225, 54, 40, 14
    
    AUTOCHECKBOX    "Sempre perguntar destino ao adicionar", IDC_CHK_ASKFOLDER, 10, 75, 250, 10

    LTEXT           "Maximo de Conexoes Globais (1-300):", IDC_STATIC, 10, 95, 150, 10
    EDITTEXT        IDC_EDIT_MAXCONN, 10, 107, 50, 14, ES_NUMBER | ES_AUTOHSCROLL
    
    AUTOCHECKBOX    "Modo Agressivo (Forcar reconexoes)", IDC_CHK_AGGRESSIVE, 10, 130, 250, 10
    
    DEFPUSHBUTTON   "Salvar", IDOK, 160, 175, 50, 14
    PUSHBUTTON      "Cancelar", IDCANCEL, 215, 175, 50, 14
END
